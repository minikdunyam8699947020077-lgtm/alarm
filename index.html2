<link rel="icon" type="image/png" href="favicon.png">
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;500;600;700;800&display=swap');

:root {
  --bg: #060b14;
  --bg2: #0d1525;
  --bg3: #111c30;
  --card: #0f1a2e;
  --card2: #162036;
  --border: #1e2f4a;
  --accent: #00d4ff;
  --accent2: #0099cc;
  --accent3: #ff6b35;
  --green: #00ff88;
  --purple: #a855f7;
  --text: #e8f0fe;
  --text2: #8ba4c8;
  --text3: #4a6080;
  --glow: 0 0 20px rgba(0,212,255,0.3);
  --glow2: 0 0 40px rgba(0,212,255,0.15);
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Syne', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ANIMATED BG */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background: 
    radial-gradient(ellipse 800px 500px at 20% 20%, rgba(0,100,255,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 600px 400px at 80% 80%, rgba(0,212,255,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 400px 300px at 50% 50%, rgba(168,85,247,0.03) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* GRID OVERLAY */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: 
    linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
  z-index: 0;
}

/* NAV */
nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(6,11,20,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
}

.nav-logo {
  font-size: 18px;
  font-weight: 800;
  color: var(--accent);
  letter-spacing: -0.5px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
}

.nav-logo span {
  width: 28px;
  height: 28px;
  background: var(--accent);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.nav-tabs {
  display: flex;
  gap: 2px;
  overflow-x: auto;
  scrollbar-width: none;
}

.nav-tabs::-webkit-scrollbar { display: none; }

.nav-tab {
  padding: 8px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 500;
  color: var(--text2);
  transition: all 0.2s;
  white-space: nowrap;
  border: 1px solid transparent;
}

.nav-tab:hover {
  color: var(--text);
  background: var(--bg3);
  border-color: var(--border);
}

.nav-tab.active {
  color: var(--accent);
  background: rgba(0,212,255,0.08);
  border-color: rgba(0,212,255,0.2);
}

/* PAGES */
.page { display: none; padding: 40px 24px; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
.page.active { display: block; }

/* CLOCK DISPLAY */
.clock-hero {
  text-align: center;
  padding: 40px 0 30px;
}

.clock-date {
  font-size: 14px;
  color: var(--text2);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 12px;
  font-family: 'Space Mono', monospace;
}

.clock-time-big {
  font-family: 'Space Mono', monospace;
  font-size: clamp(56px, 12vw, 96px);
  font-weight: 700;
  color: var(--text);
  letter-spacing: -4px;
  line-height: 1;
  text-shadow: 0 0 40px rgba(0,212,255,0.2);
  position: relative;
}

.clock-time-big .colon {
  color: var(--accent);
  animation: blink 1s step-end infinite;
}

@keyframes blink { 50% { opacity: 0.3; } }

/* CARDS */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 20px;
  transition: border-color 0.3s;
}

.card:hover { border-color: rgba(0,212,255,0.2); }

.card-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-title::before {
  content: '';
  width: 3px;
  height: 14px;
  background: var(--accent);
  border-radius: 2px;
}

/* TIME PICKER */
.time-pickers {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

.picker-wrap {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.picker-label {
  font-size: 12px;
  color: var(--text2);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.picker-scroll {
  height: 160px;
  overflow-y: auto;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--bg2);
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  scroll-snap-type: y mandatory;
}

.picker-scroll::-webkit-scrollbar { width: 4px; }
.picker-scroll::-webkit-scrollbar-track { background: transparent; }
.picker-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.picker-item {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Space Mono', monospace;
  font-size: 20px;
  font-weight: 700;
  color: var(--text3);
  cursor: pointer;
  transition: all 0.2s;
  scroll-snap-align: start;
}

.picker-item:hover { color: var(--text); background: var(--bg3); }
.picker-item.selected {
  color: var(--accent);
  background: rgba(0,212,255,0.08);
  border-left: 2px solid var(--accent);
}

/* QUICK TIMES */
.quick-times {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 20px;
}

.quick-btn {
  padding: 8px 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg2);
  color: var(--text2);
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}

.quick-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0,212,255,0.05);
}

/* SOUND PICKER */
.sounds-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 8px;
  margin-bottom: 16px;
}

.sound-btn {
  padding: 10px 8px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--bg2);
  color: var(--text2);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}

.sound-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.sound-btn.selected {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0,212,255,0.08);
}

/* INPUTS */
input[type="text"], input[type="number"], input[type="date"] {
  width: 100%;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 16px;
  color: var(--text);
  font-family: 'Syne', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}

input:focus { border-color: var(--accent); }

/* BUTTONS */
.btn {
  padding: 14px 28px;
  border-radius: 10px;
  border: none;
  font-family: 'Syne', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.5px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary {
  background: var(--accent);
  color: var(--bg);
  width: 100%;
  justify-content: center;
  font-size: 15px;
}

.btn-primary:hover {
  background: #00b8d9;
  transform: translateY(-1px);
  box-shadow: var(--glow);
}

.btn-secondary {
  background: var(--bg3);
  color: var(--text2);
  border: 1px solid var(--border);
}

.btn-secondary:hover { color: var(--text); border-color: var(--text3); }

.btn-danger {
  background: rgba(255,107,53,0.1);
  color: var(--accent3);
  border: 1px solid rgba(255,107,53,0.3);
}

.btn-danger:hover { background: rgba(255,107,53,0.2); }

.btn-green {
  background: rgba(0,255,136,0.1);
  color: var(--green);
  border: 1px solid rgba(0,255,136,0.3);
}

.btn-green:hover { background: rgba(0,255,136,0.2); }

/* COUNTDOWN DISPLAY */
.countdown-display {
  display: none;
  margin-top: 20px;
}

.countdown-display.visible { display: block; }

.countdown-ring {
  text-align: center;
  padding: 32px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 16px;
  position: relative;
  overflow: hidden;
}

.countdown-ring::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(0,212,255,0.04) 0%, transparent 70%);
}

.countdown-num {
  font-family: 'Space Mono', monospace;
  font-size: clamp(36px, 8vw, 64px);
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -2px;
  text-shadow: var(--glow);
}

.countdown-label {
  font-size: 13px;
  color: var(--text2);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 8px;
}

.countdown-progress {
  height: 3px;
  background: var(--border);
  border-radius: 2px;
  margin-top: 20px;
  overflow: hidden;
}

.countdown-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--purple));
  border-radius: 2px;
  transition: width 1s linear;
  width: 100%;
}

/* ALARM RING MODAL */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(6,11,20,0.95);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}

.modal-overlay.visible { display: flex; }

.modal-box {
  background: var(--card);
  border: 1px solid var(--accent);
  border-radius: 24px;
  padding: 48px 40px;
  text-align: center;
  max-width: 400px;
  width: 90%;
  box-shadow: 0 0 80px rgba(0,212,255,0.2);
  animation: modalPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalPop {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-icon {
  font-size: 64px;
  margin-bottom: 16px;
  animation: ring 0.5s ease infinite alternate;
}

@keyframes ring {
  from { transform: rotate(-15deg); }
  to { transform: rotate(15deg); }
}

.modal-title {
  font-size: 28px;
  font-weight: 800;
  color: var(--accent);
  margin-bottom: 8px;
}

.modal-time {
  font-family: 'Space Mono', monospace;
  font-size: 48px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
}

.modal-name { color: var(--text2); margin-bottom: 32px; font-size: 16px; }

.modal-btns { display: flex; gap: 12px; }
.modal-btns .btn { flex: 1; justify-content: center; }

/* HISTORY TABLE */
.history-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.history-table th {
  text-align: left;
  padding: 10px 12px;
  color: var(--text2);
  border-bottom: 1px solid var(--border);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.history-table td {
  padding: 12px;
  border-bottom: 1px solid rgba(30,47,74,0.5);
  color: var(--text2);
}

.history-table tr:hover td { background: var(--bg3); }

/* STOPWATCH */
.stopwatch-display {
  text-align: center;
  padding: 40px 20px;
}

.sw-time {
  font-family: 'Space Mono', monospace;
  font-size: clamp(48px, 10vw, 80px);
  font-weight: 700;
  color: var(--text);
  letter-spacing: -2px;
  text-shadow: 0 0 30px rgba(0,212,255,0.15);
}

.sw-ms {
  font-family: 'Space Mono', monospace;
  font-size: clamp(24px, 5vw, 40px);
  color: var(--accent);
}

.sw-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 24px;
  flex-wrap: wrap;
}

.laps-list {
  max-height: 240px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

.lap-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 16px;
  border-bottom: 1px solid rgba(30,47,74,0.5);
  font-family: 'Space Mono', monospace;
  font-size: 13px;
}

.lap-item:hover { background: var(--bg3); }

.lap-num { color: var(--text3); }
.lap-time { color: var(--text); }
.lap-diff { color: var(--text2); font-size: 11px; }

/* TIMER */
.timer-input-row {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}

.timer-unit {
  flex: 1;
  min-width: 80px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.timer-display {
  text-align: center;
  padding: 40px 20px;
}

.timer-num {
  font-family: 'Space Mono', monospace;
  font-size: clamp(48px, 10vw, 80px);
  font-weight: 700;
  letter-spacing: -2px;
}

.timer-circle {
  position: relative;
  width: 240px;
  height: 240px;
  margin: 0 auto 24px;
}

.timer-circle svg {
  transform: rotate(-90deg);
  width: 240px;
  height: 240px;
}

.timer-circle-text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* COUNTDOWN PAGE */
.countdown-page-input {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}

.countdown-big {
  text-align: center;
  padding: 48px 20px;
}

.countdown-units {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

.countdown-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  min-width: 90px;
}

.countdown-unit-num {
  font-family: 'Space Mono', monospace;
  font-size: clamp(40px, 8vw, 64px);
  font-weight: 700;
  color: var(--text);
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px 16px;
  min-width: 90px;
  text-align: center;
  line-height: 1;
}

.countdown-unit-label {
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.countdown-sep {
  font-family: 'Space Mono', monospace;
  font-size: 48px;
  font-weight: 700;
  color: var(--accent);
  align-self: flex-start;
  padding-top: 12px;
  line-height: 1.2;
}

/* CLOCK PAGE */
.clock-page-display {
  text-align: center;
  padding: 48px 20px;
}

.clock-analog {
  width: 200px;
  height: 200px;
  border: 2px solid var(--border);
  border-radius: 50%;
  margin: 0 auto 32px;
  position: relative;
  background: var(--card);
  box-shadow: 0 0 40px rgba(0,212,255,0.1), inset 0 0 40px rgba(0,0,0,0.3);
}

.clock-hand {
  position: absolute;
  bottom: 50%;
  left: 50%;
  transform-origin: bottom center;
  border-radius: 3px;
}

.hand-hour {
  width: 3px;
  height: 55px;
  background: var(--text);
  margin-left: -1.5px;
}

.hand-min {
  width: 2px;
  height: 72px;
  background: var(--accent);
  margin-left: -1px;
}

.hand-sec {
  width: 1px;
  height: 80px;
  background: var(--accent3);
  margin-left: -0.5px;
}

.clock-center {
  position: absolute;
  width: 8px;
  height: 8px;
  background: var(--accent);
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  box-shadow: var(--glow);
}

/* WORLD CLOCKS */
.world-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

.world-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
  transition: border-color 0.2s, transform 0.2s;
}

.world-card:hover {
  border-color: rgba(0,212,255,0.3);
  transform: translateY(-2px);
}

.world-city {
  font-size: 12px;
  color: var(--text2);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.world-flag { font-size: 20px; margin-bottom: 4px; }

.world-time {
  font-family: 'Space Mono', monospace;
  font-size: 24px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1px;
}

.world-offset {
  font-size: 11px;
  color: var(--text3);
  margin-top: 4px;
}

/* DATE/AGE CALC */
.calc-result {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  margin-top: 16px;
  display: none;
}

.calc-result.visible { display: block; }

.result-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 12px;
  margin-top: 12px;
}

.result-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px;
  text-align: center;
}

.result-num {
  font-family: 'Space Mono', monospace;
  font-size: 28px;
  font-weight: 700;
  color: var(--accent);
}

.result-unit {
  font-size: 11px;
  color: var(--text2);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-top: 4px;
}

/* SECTION TITLE */
.section-title {
  font-size: 24px;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 8px;
}

.section-sub {
  font-size: 14px;
  color: var(--text2);
  margin-bottom: 32px;
  line-height: 1.6;
}

/* VOL SLIDER */
input[type="range"] {
  width: 100%;
  appearance: none;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}

input[type="range"]::-webkit-slider-thumb {
  appearance: none;
  width: 16px;
  height: 16px;
  background: var(--accent);
  border-radius: 50%;
  cursor: pointer;
  box-shadow: var(--glow);
}

/* SETTINGS MODAL */
.settings-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(6,11,20,0.9);
  z-index: 500;
  align-items: center;
  justify-content: center;
}

.settings-modal.visible { display: flex; }

.settings-box {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 32px;
  width: min(460px, 90vw);
  max-height: 80vh;
  overflow-y: auto;
}

.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}

.settings-row:last-child { border-bottom: none; }

.settings-label { font-size: 14px; color: var(--text); }
.settings-desc { font-size: 12px; color: var(--text2); margin-top: 2px; }

/* TOGGLE */
.toggle {
  width: 44px;
  height: 24px;
  background: var(--border);
  border-radius: 12px;
  cursor: pointer;
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.toggle.on { background: var(--accent); }

.toggle::after {
  content: '';
  position: absolute;
  width: 18px;
  height: 18px;
  background: white;
  border-radius: 50%;
  top: 3px;
  left: 3px;
  transition: left 0.2s;
}

.toggle.on::after { left: 23px; }

/* FOOTER */
footer {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 40px 24px;
  margin-top: 60px;
  position: relative;
  z-index: 1;
}

.footer-grid {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 32px;
  margin-bottom: 32px;
}

.footer-col h4 {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text2);
  margin-bottom: 16px;
  font-weight: 600;
}

.footer-col a {
  display: block;
  color: var(--text3);
  text-decoration: none;
  font-size: 14px;
  padding: 4px 0;
  transition: color 0.2s;
  cursor: pointer;
}

.footer-col a:hover { color: var(--accent); }

.footer-bottom {
  max-width: 900px;
  margin: 0 auto;
  padding-top: 24px;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: gap;
  gap: 12px;
}

.footer-copy { font-size: 13px; color: var(--text3); }

/* SNACK */
.snack {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--card);
  border: 1px solid var(--accent);
  border-radius: 10px;
  padding: 12px 20px;
  font-size: 14px;
  color: var(--accent);
  z-index: 2000;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  white-space: nowrap;
  box-shadow: var(--glow);
}

.snack.show { transform: translateX(-50%) translateY(0); }

/* TABS SUB */
.sub-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.sub-tab {
  padding: 8px 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  color: var(--text2);
  transition: all 0.2s;
}

.sub-tab.active, .sub-tab:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0,212,255,0.05);
}

/* RESPONSIVE */
@media (max-width: 600px) {
  .time-pickers { grid-template-columns: 1fr 1fr; }
  .nav-tab { padding: 6px 10px; font-size: 12px; }
  .modal-btns { flex-direction: column; }
}

/* TIMEZONE TABLE */
.tz-table {
  width: 100%;
  border-collapse: collapse;
}

.tz-table th, .tz-table td {
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}

.tz-table th {
  color: var(--text2);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.tz-table td { color: var(--text); }
.tz-table tr:hover td { background: var(--bg3); }

/* WEEK NUM */
.week-big {
  text-align: center;
  padding: 60px 20px;
}

.week-number {
  font-family: 'Space Mono', monospace;
  font-size: 120px;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
  text-shadow: 0 0 60px rgba(0,212,255,0.3);
}

.week-label {
  font-size: 14px;
  color: var(--text2);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-top: 8px;
}

/* HOURS CALC */
.hours-rows {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 16px;
}

.hours-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 10px;
  align-items: center;
}

.alarm-ringing {
  animation: alarmGlow 0.5s ease infinite alternate;
}

@keyframes alarmGlow {
  from { box-shadow: 0 0 20px rgba(0,212,255,0.2); }
  to { box-shadow: 0 0 60px rgba(0,212,255,0.5), 0 0 100px rgba(0,212,255,0.2); }
}

.btn-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg2);
  color: var(--text2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  transition: all 0.2s;
}

.btn-icon:hover { border-color: var(--accent); color: var(--accent); }

nav .settings-btn {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text2);
  border-radius: 8px;
  padding: 6px 10px;
  cursor: pointer;
  font-size: 16px;
  transition: all 0.2s;
}

nav .settings-btn:hover { color: var(--text); border-color: var(--text3); }

/* LANGUAGE SWITCHER */
.lang-switcher {
  position: relative;
  display: inline-block;
}

.lang-btn {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text2);
  border-radius: 8px;
  padding: 6px 10px;
  cursor: pointer;
  font-size: 13px;
  font-family: 'Syne', sans-serif;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
}

.lang-btn:hover { color: var(--text); border-color: var(--text3); }

.lang-dropdown {
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 6px);
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 6px;
  z-index: 200;
  min-width: 180px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  max-height: 320px;
  overflow-y: auto;
}

.lang-dropdown.open { display: block; }

.lang-option {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
  color: var(--text2);
  transition: all 0.15s;
}

.lang-option:hover { background: var(--bg3); color: var(--text); }
.lang-option.active { background: rgba(0,212,255,0.08); color: var(--accent); }
.lang-option .lang-flag { font-size: 16px; }
.lang-option .lang-name { flex: 1; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo" onclick="showPage('alarm')">
    <span>⏰</span> Online Alarm
  </div>
  <div class="nav-tabs">
    <div class="nav-tab active" onclick="showPage('alarm')">Alarm</div>
    <div class="nav-tab" onclick="showPage('timer')">Zamanlayıcı</div>
    <div class="nav-tab" onclick="showPage('stopwatch')">Kronometre</div>
    <div class="nav-tab" onclick="showPage('countdown')">Geri Sayım</div>
    <div class="nav-tab" onclick="showPage('clock')">Saat</div>
    <div class="nav-tab" onclick="showPage('world')">Dünya Saatleri</div>
    <div class="nav-tab" onclick="showPage('timezone')">Saat Dilimleri</div>
    <div class="nav-tab" onclick="showPage('week')">Hafta No</div>
    <div class="nav-tab" onclick="showPage('date')">Tarih Hesapla</div>
    <div class="nav-tab" onclick="showPage('hours')">Saat Hesapla</div>
    <div class="nav-tab" onclick="showPage('age')">Yaş Hesapla</div>
  </div>
  <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
    <div class="lang-switcher" id="langSwitcher">
      <button class="lang-btn" onclick="toggleLangDropdown()" id="langBtnLabel">🌐 TR</button>
      <div class="lang-dropdown" id="langDropdown"></div>
    </div>
    <button class="settings-btn" onclick="document.getElementById('settingsModal').classList.toggle('visible')">⚙️</button>
  </div>
</nav>

<!-- ALARM PAGE -->
<div class="page active" id="page-alarm">
  <div class="clock-hero">
    <div class="clock-date" id="alarmDate">—</div>
    <div class="clock-time-big" id="alarmClock">00<span class="colon">:</span>00<span class="colon">:</span>00</div>
  </div>

  <div class="card">
    <div class="card-title">Alarm Saatini Ayarla</div>
    <div class="time-pickers">
      <div class="picker-wrap">
        <div class="picker-label">Saat</div>
        <div class="picker-scroll" id="hourPicker"></div>
      </div>
      <div class="picker-wrap">
        <div class="picker-label">Dakika</div>
        <div class="picker-scroll" id="minutePicker"></div>
      </div>
    </div>
    <div class="quick-times" id="quickTimes"></div>
  </div>

  <div class="card">
    <div class="card-title">Alarm Sesi</div>
    <div class="sounds-grid" id="soundsGrid"></div>
    <div style="display:flex;gap:10px;margin-top:8px;">
      <button class="btn btn-secondary" onclick="testSound()">▶ Sesi Test Et</button>
      <button class="btn btn-secondary" onclick="stopTestSound()">■ Durdur</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Alarm Başlığı</div>
    <input type="text" id="alarmTitle" placeholder="Alarm adı (isteğe bağlı)..." maxlength="50">
    <div style="margin-top:8px;font-size:12px;color:var(--text3)">
      <span id="titleCount">0</span>%
    </div>
  </div>

  <button class="btn btn-primary" onclick="setAlarm()" style="margin-bottom:20px;">
    🔔 Alarm Kur
  </button>

  <!-- COUNTDOWN DISPLAY -->
  <div class="countdown-display" id="alarmCountdown">
    <div class="card-title" style="margin-bottom:16px;">⏳ Alarm Geri Sayımı</div>
    <div class="countdown-ring alarm-ringing" id="alarmRingBox">
      <div class="countdown-num" id="alarmCountNum">--:--:--</div>
      <div class="countdown-label" id="alarmCountLabel">Alarmınız çalacak</div>
      <div class="countdown-progress">
        <div class="countdown-bar" id="alarmBar"></div>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:12px;">
      <button class="btn btn-danger" onclick="cancelAlarm()" style="flex:1;">✕ İptal</button>
    </div>
  </div>

  <div class="card" style="margin-top:20px;">
    <div class="card-title">Alarm Geçmişi</div>
    <div style="overflow-x:auto;">
      <table class="history-table" id="historyTable">
        <thead>
          <tr>
            <th>#</th>
            <th>Başlık</th>
            <th>Alarm</th>
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="historyBody">
          <tr><td colspan="6" style="text-align:center;color:var(--text3);padding:24px;">Henüz alarm kaydı yok</td></tr>
        </tbody>
      </table>
    </div>
    <div style="display:flex;gap:10px;margin-top:16px;">
      <button class="btn btn-secondary" onclick="exportCSV()">📥 CSV'ye Aktar</button>
      <button class="btn btn-secondary" onclick="clearHistory()">🗑 Temizle</button>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Online Alarm Nedir?</div>
    <p style="color:var(--text2);font-size:14px;line-height:1.8;">
      Online Alarm, zamanında uyanmanıza ve gün boyu görevler için hatırlatıcı kurmanıza yardımcı olur.
      Alarm saatini ve sesini seçin, alarmınıza isim verin, kaydedin — tarayıcı sekmesi açık olduğu
      sürece alarm belirlenen saatte otomatik çalar.
    </p>
  </div>
</div>

<!-- TIMER PAGE -->
<div class="page" id="page-timer">
  <div class="clock-hero">
    <div class="clock-date">Zamanlayıcı</div>
  </div>

  <div class="card">
    <div class="card-title">Süre Gir</div>
    <div class="timer-input-row">
      <div class="timer-unit">
        <div class="picker-label">Saat</div>
        <input type="number" id="timerH" placeholder="0" min="0" max="99" value="0" style="text-align:center;font-family:'Space Mono',monospace;font-size:24px;font-weight:700;">
      </div>
      <div style="align-self:flex-end;padding-bottom:12px;font-size:28px;color:var(--accent);font-family:'Space Mono',monospace;font-weight:700;">:</div>
      <div class="timer-unit">
        <div class="picker-label">Dakika</div>
        <input type="number" id="timerM" placeholder="0" min="0" max="59" value="0" style="text-align:center;font-family:'Space Mono',monospace;font-size:24px;font-weight:700;">
      </div>
      <div style="align-self:flex-end;padding-bottom:12px;font-size:28px;color:var(--accent);font-family:'Space Mono',monospace;font-weight:700;">:</div>
      <div class="timer-unit">
        <div class="picker-label">Saniye</div>
        <input type="number" id="timerS" placeholder="0" min="0" max="59" value="0" style="text-align:center;font-family:'Space Mono',monospace;font-size:24px;font-weight:700;">
      </div>
    </div>
    <div class="quick-times" style="margin-top:16px;">
      <button class="quick-btn" onclick="setTimer(0,1,0)">1 dk</button>
      <button class="quick-btn" onclick="setTimer(0,3,0)">3 dk</button>
      <button class="quick-btn" onclick="setTimer(0,5,0)">5 dk</button>
      <button class="quick-btn" onclick="setTimer(0,10,0)">10 dk</button>
      <button class="quick-btn" onclick="setTimer(0,15,0)">15 dk</button>
      <button class="quick-btn" onclick="setTimer(0,20,0)">20 dk</button>
      <button class="quick-btn" onclick="setTimer(0,25,0)">25 dk</button>
      <button class="quick-btn" onclick="setTimer(0,30,0)">30 dk</button>
      <button class="quick-btn" onclick="setTimer(1,0,0)">1 sa</button>
    </div>
  </div>

  <div class="timer-display">
    <div class="timer-circle">
      <svg viewBox="0 0 240 240">
        <circle cx="120" cy="120" r="108" fill="none" stroke="var(--border)" stroke-width="4"/>
        <circle cx="120" cy="120" r="108" fill="none" stroke="var(--accent)" stroke-width="4" 
          stroke-dasharray="678.6" id="timerCircle" stroke-dashoffset="0"
          stroke-linecap="round" style="transition:stroke-dashoffset 1s linear;"/>
      </svg>
      <div class="timer-circle-text">
        <div class="timer-num" id="timerDisplay" style="color:var(--text);">00:00:00</div>
      </div>
    </div>
    <div class="sw-btns">
      <button class="btn btn-primary" onclick="startTimer()" id="timerStartBtn">▶ Başlat</button>
      <button class="btn btn-secondary" onclick="pauseTimer()">⏸ Duraklat</button>
      <button class="btn btn-danger" onclick="resetTimer()">↺ Sıfırla</button>
    </div>
  </div>
</div>

<!-- STOPWATCH PAGE -->
<div class="page" id="page-stopwatch">
  <div class="clock-hero">
    <div class="clock-date">Kronometre</div>
  </div>

  <div class="card">
    <div class="stopwatch-display">
      <div class="sw-time" id="swDisplay">00:00<span class="sw-ms">.00</span></div>
    </div>
    <div class="sw-btns">
      <button class="btn btn-primary" onclick="swStart()" id="swStartBtn">▶ Başlat</button>
      <button class="btn btn-secondary" onclick="swLap()" id="swLapBtn" disabled>🏁 Tur</button>
      <button class="btn btn-danger" onclick="swReset()">↺ Sıfırla</button>
    </div>
  </div>

  <div class="card" id="lapsCard" style="display:none;">
    <div class="card-title">Tur Zamanları</div>
    <div class="laps-list" id="lapsList"></div>
  </div>
</div>

<!-- COUNTDOWN PAGE -->
<div class="page" id="page-countdown">
  <div class="clock-hero">
    <div class="clock-date">Geri Sayım</div>
  </div>

  <div class="card">
    <div class="card-title">Hedef Tarih ve Saat</div>
    <div class="countdown-page-input">
      <div>
        <div class="picker-label" style="margin-bottom:8px;">Tarih</div>
        <input type="date" id="cdDate">
      </div>
      <div>
        <div class="picker-label" style="margin-bottom:8px;">Saat</div>
        <input type="time" id="cdTime" value="00:00" style="text-align:center;">
      </div>
    </div>
    <input type="text" id="cdTitle" placeholder="Etkinlik adı (örn: Yeni Yıl 2027)" style="margin-bottom:16px;">
    <button class="btn btn-primary" onclick="startCountdown()">⏳ Geri Sayımı Başlat</button>
  </div>

  <div class="countdown-big" id="cdDisplay" style="display:none;">
    <div class="section-title" id="cdEventTitle" style="margin-bottom:32px;color:var(--accent);"></div>
    <div class="countdown-units">
      <div class="countdown-unit">
        <div class="countdown-unit-num" id="cdDays">00</div>
        <div class="countdown-unit-label">Gün</div>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit">
        <div class="countdown-unit-num" id="cdHours">00</div>
        <div class="countdown-unit-label">Saat</div>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit">
        <div class="countdown-unit-num" id="cdMins">00</div>
        <div class="countdown-unit-label">Dakika</div>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-unit">
        <div class="countdown-unit-num" id="cdSecs">00</div>
        <div class="countdown-unit-label">Saniye</div>
      </div>
    </div>
    <button class="btn btn-danger" onclick="stopCountdown()" style="margin-top:32px;">✕ Durdur</button>
  </div>
</div>

<!-- CLOCK PAGE -->
<div class="page" id="page-clock">
  <div class="clock-page-display">
    <div class="clock-date" id="clockPageDate" style="font-size:16px;margin-bottom:24px;">—</div>
    <div class="clock-analog" id="analogClock">
      <div class="clock-hand hand-hour" id="handHour"></div>
      <div class="clock-hand hand-min" id="handMin"></div>
      <div class="clock-hand hand-sec" id="handSec"></div>
      <div class="clock-center"></div>
    </div>
    <div class="clock-time-big" id="clockPageTime" style="font-size:clamp(48px,10vw,80px);">00<span class="colon">:</span>00<span class="colon">:</span>00</div>
  </div>
</div>

<!-- WORLD CLOCKS PAGE -->
<div class="page" id="page-world">
  <div class="section-title">🌍 Dünya Saatleri</div>
  <div class="section-sub">Dünyanın farklı şehirlerindeki anlık saat bilgileri</div>
  <div class="world-grid" id="worldGrid"></div>
</div>

<!-- TIMEZONE PAGE -->
<div class="page" id="page-timezone">
  <div class="section-title">🗺 Saat Dilimleri</div>
  <div class="section-sub">Dünyanın tüm saat dilimlerini ve UTC farklarını görüntüleyin</div>
  <div class="card">
    <div style="overflow-x:auto;">
      <table class="tz-table" id="tzTable">
        <thead>
          <tr>
            <th>Saat Dilimi</th>
            <th>UTC Farkı</th>
            <th>Yerel Saat</th>
          </tr>
        </thead>
        <tbody id="tzBody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- WEEK PAGE -->
<div class="page" id="page-week">
  <div class="week-big">
    <div class="week-label" style="margin-bottom:16px;">Bu Hafta</div>
    <div class="week-number" id="weekNum">—</div>
    <div class="week-label">. HAFTA</div>
    <div style="margin-top:32px;color:var(--text2);font-size:14px;" id="weekInfo"></div>
  </div>
  <div class="card">
    <div class="card-title">Yılın Hafta Takvimi</div>
    <div id="weekCalendar" style="overflow-x:auto;"></div>
  </div>
</div>

<!-- DATE CALC PAGE -->
<div class="page" id="page-date">
  <div class="section-title">📅 Tarih Hesaplama</div>
  <div class="section-sub">İki tarih arasındaki farkı hesaplayın</div>
  <div class="card">
    <div class="card-title">Tarihler</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div>
        <div class="picker-label" style="margin-bottom:8px;">Başlangıç Tarihi</div>
        <input type="date" id="dateFrom">
      </div>
      <div>
        <div class="picker-label" style="margin-bottom:8px;">Bitiş Tarihi</div>
        <input type="date" id="dateTo">
      </div>
    </div>
    <button class="btn btn-primary" onclick="calcDate()">Hesapla</button>
    <div class="calc-result" id="dateResult">
      <div class="card-title">Sonuç</div>
      <div class="result-grid" id="dateResultGrid"></div>
    </div>
  </div>
</div>

<!-- HOURS CALC PAGE -->
<div class="page" id="page-hours">
  <div class="section-title">⏱ Saat Hesaplama</div>
  <div class="section-sub">Çalışma saatlerini ve süre farklarını hesaplayın</div>
  <div class="card">
    <div class="card-title">Saat Aralıkları</div>
    <div class="hours-rows" id="hoursRows">
      <div class="hours-row">
        <input type="time" class="start-time">
        <input type="time" class="end-time">
        <button class="btn-icon" onclick="removeHoursRow(this)">✕</button>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:16px;">
      <button class="btn btn-secondary" onclick="addHoursRow()">+ Satır Ekle</button>
    </div>
    <button class="btn btn-primary" onclick="calcHours()">Hesapla</button>
    <div class="calc-result" id="hoursResult">
      <div class="card-title">Toplam Süre</div>
      <div id="hoursResultText" style="font-family:'Space Mono',monospace;font-size:32px;color:var(--accent);margin-top:12px;"></div>
    </div>
  </div>
</div>

<!-- AGE CALC PAGE -->
<div class="page" id="page-age">
  <div class="section-title">🎂 Yaş Hesaplama</div>
  <div class="section-sub">Doğum tarihinizi girerek yaşınızı detaylı hesaplayın</div>
  <div class="card">
    <div class="card-title">Doğum Tarihi</div>
    <div style="margin-bottom:16px;">
      <div class="picker-label" style="margin-bottom:8px;">Doğum Tarihi</div>
      <input type="date" id="birthDate">
    </div>
    <button class="btn btn-primary" onclick="calcAge()">Hesapla</button>
    <div class="calc-result" id="ageResult">
      <div class="card-title">Yaş Bilgileri</div>
      <div class="result-grid" id="ageResultGrid"></div>
      <div id="ageExtra" style="margin-top:16px;color:var(--text2);font-size:14px;line-height:1.8;"></div>
    </div>
  </div>
</div>

<!-- ALARM RING MODAL -->
<div class="modal-overlay" id="alarmModal">
  <div class="modal-box">
    <div class="modal-icon">⏰</div>
    <div class="modal-title">ALARM!</div>
    <div class="modal-time" id="modalTime">00:00</div>
    <div class="modal-name" id="modalName">Alarm çalıyor</div>
    <div class="modal-btns">
      <button class="btn btn-danger" onclick="stopAlarm()">■ Durdur</button>
      <button class="btn btn-secondary" onclick="snoozeAlarm()">💤 Ertele</button>
    </div>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div class="settings-modal" id="settingsModal">
  <div class="settings-box">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
      <div style="font-size:18px;font-weight:800;">⚙️ Ayarlar</div>
      <button class="btn-icon" onclick="document.getElementById('settingsModal').classList.remove('visible')">✕</button>
    </div>
    <div class="settings-row">
      <div><div class="settings-label">Alarmı tekrarla</div><div class="settings-desc">Kapatılana kadar çalar</div></div>
      <div class="toggle on" id="toggleRepeat" onclick="this.classList.toggle('on')"></div>
    </div>
    <div class="settings-row">
      <div><div class="settings-label">Alarm saatini göster</div></div>
      <div class="toggle on" id="toggleShowTime" onclick="this.classList.toggle('on')"></div>
    </div>
    <div class="settings-row">
      <div><div class="settings-label">İlerleme çubuğunu göster</div></div>
      <div class="toggle on" id="toggleProgress" onclick="this.classList.toggle('on')"></div>
    </div>
    <div class="settings-row" style="flex-direction:column;align-items:flex-start;gap:12px;">
      <div class="settings-label">Alarm erteleme süresi: <span id="snoozeVal">10</span> dk</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="quick-btn" onclick="setSnooze(1)">1</button>
        <button class="quick-btn" onclick="setSnooze(5)">5</button>
        <button class="quick-btn" onclick="setSnooze(10)">10</button>
        <button class="quick-btn" onclick="setSnooze(15)">15</button>
        <button class="quick-btn" onclick="setSnooze(30)">30</button>
      </div>
    </div>
    <div class="settings-row" style="flex-direction:column;align-items:flex-start;gap:12px;">
      <div class="settings-label">Ses seviyesi: <span id="volVal">100</span>%</div>
      <input type="range" id="volSlider" min="0" max="100" value="100" oninput="document.getElementById('volVal').textContent=this.value">
    </div>
    <button class="btn btn-secondary" style="margin-top:16px;width:100%;" onclick="document.getElementById('settingsModal').classList.remove('visible')">Kapat</button>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-grid">
    <div class="footer-col">
      <h4>Zamanlayıcılar</h4>
      <a onclick="showPage('alarm')">Online Alarm Kur</a>
      <a onclick="showPage('timer')">Online Zamanlayıcı</a>
      <a onclick="showPage('stopwatch')">Online Kronometre</a>
      <a onclick="showPage('countdown')">Geri Sayım Sayacı</a>
    </div>
    <div class="footer-col">
      <h4>Zaman</h4>
      <a onclick="showPage('clock')">Online Saat</a>
      <a onclick="showPage('world')">Dünya Saatleri</a>
      <a onclick="showPage('timezone')">Saat Dilimleri</a>
      <a onclick="showPage('week')">Hafta Numarası</a>
    </div>
    <div class="footer-col">
      <h4>Hesaplayıcılar</h4>
      <a onclick="showPage('date')">Tarih Hesaplama</a>
      <a onclick="showPage('hours')">Saat Hesaplama</a>
      <a onclick="showPage('age')">Yaş Hesaplama</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">© 2026 Online Alarm Kur — Tüm hakları saklıdır</div>
    <div style="font-size:13px;color:var(--text3);">TR Türkçe</div>
  </div>
</footer>

<!-- GOOGLE TRANSLATE CONTAINER -->
<div id="google_translate_element"></div>

<!-- SNACK -->
<div class="snack" id="snack"></div>

<script>
// ==================== STATE ====================
let alarmHour = 7, alarmMin = 0;
let alarmTimeout = null;
let alarmInterval = null;
let alarmStartTime = null;
let alarmTargetTime = null;
let selectedSound = 'Çalar Saat';
let alarmAudio = null;
let alarmHistory = JSON.parse(localStorage.getItem('alarmHistory') || '[]');
let snoozeMins = 10;

// Stopwatch
let swRunning = false, swStarted = false;
let swStartTs = 0, swElapsed = 0;
let swInterval = null;
let swLaps = [];
let swLastLapTime = 0;

// Timer
let timerRunning = false;
let timerTotal = 0, timerRemaining = 0;
let timerInterval = null;

// Countdown
let cdInterval = null;
let cdTarget = null;

// ==================== PAGES ====================
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const tabs = document.querySelectorAll('.nav-tab');
  const map = {alarm:0,timer:1,stopwatch:2,countdown:3,clock:4,world:5,timezone:6,week:7,date:8,hours:9,age:10};
  if(map[name] !== undefined) tabs[map[name]].classList.add('active');
  if(name === 'world') updateWorldClocks();
  if(name === 'timezone') updateTZTable();
  if(name === 'week') updateWeek();
}

// ==================== CLOCK ====================
const DAYS = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
const MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];

function pad(n){return String(n).padStart(2,'0');}

function updateClocks() {
  const now = new Date();
  const h = pad(now.getHours()), m = pad(now.getMinutes()), s = pad(now.getSeconds());
  const dateStr = `${DAYS[now.getDay()]}, ${now.getDate()} ${MONTHS[now.getMonth()]} ${now.getFullYear()}`;

  // Alarm clock
  document.getElementById('alarmClock').innerHTML = `${h}<span class="colon">:</span>${m}<span class="colon">:</span>${s}`;
  document.getElementById('alarmDate').textContent = dateStr;

  // Clock page
  document.getElementById('clockPageTime').innerHTML = `${h}<span class="colon">:</span>${m}<span class="colon">:</span>${s}`;
  document.getElementById('clockPageDate').textContent = dateStr;

  // Analog
  const sec = now.getSeconds(), min = now.getMinutes(), hour = now.getHours();
  const secDeg = sec * 6;
  const minDeg = min * 6 + sec * 0.1;
  const hourDeg = (hour % 12) * 30 + min * 0.5;
  document.getElementById('handSec').style.transform = `rotate(${secDeg}deg)`;
  document.getElementById('handMin').style.transform = `rotate(${minDeg}deg)`;
  document.getElementById('handHour').style.transform = `rotate(${hourDeg}deg)`;

  // Alarm countdown
  if(alarmTargetTime) {
    const diff = alarmTargetTime - now.getTime();
    if(diff <= 0) {
      triggerAlarm();
    } else {
      const totalSecs = Math.floor(diff / 1000);
      const hh = Math.floor(totalSecs/3600), mm = Math.floor((totalSecs%3600)/60), ss = totalSecs%60;
      document.getElementById('alarmCountNum').textContent = `${pad(hh)}:${pad(mm)}:${pad(ss)}`;
      const elapsed = now.getTime() - alarmStartTime;
      const total = alarmTargetTime - alarmStartTime;
      const pct = Math.max(0, 100 - (elapsed/total*100));
      document.getElementById('alarmBar').style.width = pct + '%';
    }
  }
}

setInterval(updateClocks, 1000);
updateClocks();

// ==================== HOUR/MIN PICKERS ====================
function buildPicker(id, count, selected) {
  const el = document.getElementById(id);
  el.innerHTML = '';
  for(let i=0;i<count;i++){
    const div = document.createElement('div');
    div.className = 'picker-item' + (i===selected?' selected':'');
    div.textContent = pad(i);
    div.onclick = () => {
      el.querySelectorAll('.picker-item').forEach(x=>x.classList.remove('selected'));
      div.classList.add('selected');
      if(id==='hourPicker') alarmHour = i;
      else alarmMin = i;
    };
    el.appendChild(div);
  }
  // scroll to selected
  setTimeout(()=>{
    const sel = el.querySelector('.selected');
    if(sel) el.scrollTop = sel.offsetTop - el.clientHeight/2 + sel.clientHeight/2;
  },50);
}

buildPicker('hourPicker', 24, 7);
buildPicker('minutePicker', 60, 0);

// Quick times
const quickTimes = [
  {h:5,m:0},{h:5,m:30},{h:6,m:0},{h:6,m:30},{h:7,m:0},{h:7,m:30},{h:8,m:0},{h:8,m:30}
];

const qtEl = document.getElementById('quickTimes');
quickTimes.forEach(t => {
  const btn = document.createElement('button');
  btn.className = 'quick-btn';
  btn.textContent = `${pad(t.h)}:${pad(t.m)}`;
  btn.onclick = () => {
    alarmHour = t.h; alarmMin = t.m;
    buildPicker('hourPicker',24,t.h);
    buildPicker('minutePicker',60,t.m);
  };
  qtEl.appendChild(btn);
});

// ==================== SOUNDS ====================
const sounds = ['Çalar Saat','Saat Zili','Horoz','Siren','Nükleer','Ezan','Uzaylılar','Yağmur','Bomba','Mistik','Çan','Beyaz Gürültü'];
const soundIcons = {'Çalar Saat':'⏰','Saat Zili':'🔔','Horoz':'🐓','Siren':'🚨','Nükleer':'☢️','Ezan':'🕌','Uzaylılar':'👽','Yağmur':'🌧️','Bomba':'💣','Mistik':'🔮','Çan':'🎐','Beyaz Gürültü':'〰️'};

const sgEl = document.getElementById('soundsGrid');
sounds.forEach(s => {
  const btn = document.createElement('button');
  btn.className = 'sound-btn' + (s===selectedSound?' selected':'');
  btn.innerHTML = `${soundIcons[s]||'🔊'}<br>${s}`;
  btn.onclick = () => {
    selectedSound = s;
    sgEl.querySelectorAll('.sound-btn').forEach(x=>x.classList.remove('selected'));
    btn.classList.add('selected');
  };
  sgEl.appendChild(btn);
});

// ==================== AUDIO ====================
function createAlarmOscillator(type='sine', freq=440, pattern='beep') {
  const ctx = new (window.AudioContext || window.webkitAudioContext)();
  const vol = parseInt(document.getElementById('volSlider').value)/100;
  const gainNode = ctx.createGain();
  gainNode.gain.value = vol;
  gainNode.connect(ctx.destination);

  let stopped = false;

  function beep(f, dur, delay=0) {
    setTimeout(()=>{
      if(stopped) return;
      const osc = ctx.createOscillator();
      osc.type = type;
      osc.frequency.value = f;
      osc.connect(gainNode);
      osc.start();
      osc.stop(ctx.currentTime + dur);
    }, delay);
  }

  function playPattern() {
    if(stopped) return;
    switch(pattern) {
      case 'beep': beep(freq,0.2,0); beep(freq,0.2,400); beep(freq,0.2,800); break;
      case 'ring': for(let i=0;i<6;i++) beep(freq,0.08,i*150); break;
      case 'rooster': beep(600,0.3,0); beep(800,0.3,400); beep(1000,0.5,800); beep(800,0.3,1400); break;
      case 'siren': for(let i=0;i<8;i++){beep(800+i*50,0.15,i*200); beep(1200-i*50,0.15,i*200+100);} break;
      case 'nuclear': for(let i=0;i<3;i++){for(let j=0;j<5;j++) beep(200+j*40,0.1,i*800+j*100);} break;
      case 'alien': for(let i=0;i<6;i++) beep(200+Math.sin(i)*200,0.15,i*250); break;
      case 'rain': for(let i=0;i<20;i++) beep(200+Math.random()*400,0.05,Math.random()*2000); break;
      case 'bomb': beep(100,0.5,0); setTimeout(()=>{beep(50,0.8,0); beep(200,0.3,200);},500); break;
      case 'mystic': for(let i=0;i<5;i++) beep(300+i*150,0.4,i*600); break;
      case 'bell': beep(800,0.8,0); beep(600,0.5,1000); beep(900,0.4,1800); break;
      case 'noise':
        const buf = ctx.createBuffer(1,ctx.sampleRate*0.5,ctx.sampleRate);
        const data = buf.getChannelData(0);
        for(let i=0;i<data.length;i++) data[i] = (Math.random()*2-1)*0.3;
        const src = ctx.createBufferSource();
        src.buffer = buf;
        src.connect(gainNode);
        src.start();
        break;
      case 'ezan':
        for(let i=0;i<4;i++) beep([440,494,523,587][i%4],0.6,i*800);
        break;
    }
  }

  const patternMap = {'Çalar Saat':'beep','Saat Zili':'ring','Horoz':'rooster','Siren':'siren','Nükleer':'nuclear','Ezan':'ezan','Uzaylılar':'alien','Yağmur':'rain','Bomba':'bomb','Mistik':'mystic','Çan':'bell','Beyaz Gürültü':'noise'};

  const interval = setInterval(()=>{ if(!stopped) playPattern(); }, 2500);
  playPattern();

  return {
    stop: () => { stopped = true; clearInterval(interval); try{ctx.close();}catch(e){} }
  };
}

let testAudioCtx = null;
function testSound() {
  if(testAudioCtx) testAudioCtx.stop();
  const patternMap = {'Çalar Saat':'beep','Saat Zili':'ring','Horoz':'rooster','Siren':'siren','Nükleer':'nuclear','Ezan':'ezan','Uzaylılar':'alien','Yağmur':'rain','Bomba':'bomb','Mistik':'mystic','Çan':'bell','Beyaz Gürültü':'noise'};
  testAudioCtx = createAlarmOscillator('sine',440,patternMap[selectedSound]||'beep');
  setTimeout(()=>{ if(testAudioCtx){testAudioCtx.stop();testAudioCtx=null;} }, 3000);
}
function stopTestSound(){if(testAudioCtx){testAudioCtx.stop();testAudioCtx=null;}}

// Title counter
document.getElementById('alarmTitle').addEventListener('input', function(){
  document.getElementById('titleCount').textContent = this.value.length;
});

// ==================== ALARM ====================
function setAlarm() {
  if(alarmTimeout) clearTimeout(alarmTimeout);
  if(alarmInterval) clearInterval(alarmInterval);

  const now = new Date();
  let target = new Date();
  target.setHours(alarmHour, alarmMin, 0, 0);
  if(target <= now) target.setDate(target.getDate()+1);

  alarmTargetTime = target.getTime();
  alarmStartTime = now.getTime();

  document.getElementById('alarmCountdown').classList.add('visible');

  const timeStr = `${pad(alarmHour)}:${pad(alarmMin)}`;
  const titleEl = document.getElementById('alarmTitle');
  const label = titleEl.value || `Alarm - ${timeStr}`;
  document.getElementById('alarmCountLabel').textContent = `Alarm: ${timeStr}`;

  showSnack(`✅ Alarm kuruldu: ${timeStr}`);
}

function cancelAlarm() {
  alarmTargetTime = null;
  alarmStartTime = null;
  document.getElementById('alarmCountdown').classList.remove('visible');
  document.getElementById('alarmCountNum').textContent = '--:--:--';
  showSnack('❌ Alarm iptal edildi');
}

function triggerAlarm() {
  const h = pad(alarmHour), m = pad(alarmMin);
  const title = document.getElementById('alarmTitle').value || 'Alarm';

  alarmTargetTime = null;
  document.getElementById('alarmCountdown').classList.remove('visible');
  document.getElementById('modalTime').textContent = `${h}:${m}`;
  document.getElementById('modalName').textContent = title;
  document.getElementById('alarmModal').classList.add('visible');

  const patternMap = {'Çalar Saat':'beep','Saat Zili':'ring','Horoz':'rooster','Siren':'siren','Nükleer':'nuclear','Ezan':'ezan','Uzaylılar':'alien','Yağmur':'rain','Bomba':'bomb','Mistik':'mystic','Çan':'bell','Beyaz Gürültü':'noise'};
  alarmAudio = createAlarmOscillator('sine',440,patternMap[selectedSound]||'beep');

  // Add to history
  const now = new Date();
  alarmHistory.unshift({
    title: title,
    alarm: `${h}:${m}`,
    start: now.toLocaleTimeString('tr'),
    end: now.toLocaleTimeString('tr')
  });
  if(alarmHistory.length > 20) alarmHistory.pop();
  localStorage.setItem('alarmHistory', JSON.stringify(alarmHistory));
  renderHistory();
}

function stopAlarm() {
  if(alarmAudio) { alarmAudio.stop(); alarmAudio = null; }
  document.getElementById('alarmModal').classList.remove('visible');
}

function snoozeAlarm() {
  stopAlarm();
  const now = new Date();
  alarmStartTime = now.getTime();
  alarmTargetTime = now.getTime() + snoozeMins * 60 * 1000;
  document.getElementById('alarmCountdown').classList.add('visible');
  document.getElementById('alarmCountLabel').textContent = `Ertelendi: ${snoozeMins} dk`;
  showSnack(`💤 ${snoozeMins} dakika ertelendi`);
}

function setSnooze(v) {
  snoozeMins = v;
  document.getElementById('snoozeVal').textContent = v;
}

// History
function renderHistory() {
  const tbody = document.getElementById('historyBody');
  if(!alarmHistory.length) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:24px;">Henüz alarm kaydı yok</td></tr>';
    return;
  }
  tbody.innerHTML = alarmHistory.map((a,i) => `
    <tr>
      <td style="color:var(--text3);">${i+1}</td>
      <td>${a.title}</td>
      <td style="font-family:'Space Mono',monospace;color:var(--accent);">${a.alarm}</td>
      <td style="color:var(--text3);">${a.start}</td>
      <td style="color:var(--text3);">${a.end}</td>
      <td><button class="btn-icon" onclick="deleteHistory(${i})">✕</button></td>
    </tr>
  `).join('');
}

function deleteHistory(i) { alarmHistory.splice(i,1); localStorage.setItem('alarmHistory',JSON.stringify(alarmHistory)); renderHistory(); }
function clearHistory() { alarmHistory=[]; localStorage.setItem('alarmHistory',JSON.stringify(alarmHistory)); renderHistory(); }
function exportCSV() {
  const rows = [['#','Başlık','Alarm','Başlangıç','Bitiş'],...alarmHistory.map((a,i)=>[i+1,a.title,a.alarm,a.start,a.end])];
  const csv = rows.map(r=>r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download = 'alarm-gecmisi.csv';
  a.click();
}

renderHistory();

// ==================== STOPWATCH ====================
function updateSW() {
  const elapsed = swElapsed + (swRunning ? Date.now()-swStartTs : 0);
  const totalMs = elapsed;
  const ms = Math.floor((totalMs%1000)/10);
  const s = Math.floor(totalMs/1000)%60;
  const m = Math.floor(totalMs/60000)%60;
  const h = Math.floor(totalMs/3600000);
  document.getElementById('swDisplay').innerHTML =
    (h>0?`${pad(h)}:`:'') + `${pad(m)}:${pad(s)}<span class="sw-ms">.${pad(ms)}</span>`;
}

function swStart() {
  if(!swRunning) {
    swRunning = true;
    swStartTs = Date.now();
    swInterval = setInterval(updateSW, 50);
    document.getElementById('swStartBtn').textContent = '⏸ Duraklat';
    document.getElementById('swLapBtn').disabled = false;
    swStarted = true;
  } else {
    swRunning = false;
    swElapsed += Date.now()-swStartTs;
    clearInterval(swInterval);
    document.getElementById('swStartBtn').textContent = '▶ Devam';
  }
}

function swLap() {
  const elapsed = swElapsed + (swRunning ? Date.now()-swStartTs : 0);
  const lapTime = elapsed - swLastLapTime;
  swLastLapTime = elapsed;
  swLaps.unshift({num: swLaps.length+1, total: elapsed, diff: lapTime});
  renderLaps();
  document.getElementById('lapsCard').style.display = 'block';
}

function renderLaps() {
  document.getElementById('lapsList').innerHTML = swLaps.map(l => {
    const fmtMs = (ms) => {
      const s2=Math.floor(ms/1000)%60, m2=Math.floor(ms/60000)%60, h2=Math.floor(ms/3600000);
      return (h2>0?pad(h2)+':':'') + `${pad(m2)}:${pad(s2)}.${pad(Math.floor((ms%1000)/10))}`;
    };
    return `<div class="lap-item">
      <span class="lap-num">TUR ${l.num}</span>
      <span class="lap-time">${fmtMs(l.total)}</span>
      <span class="lap-diff">+${fmtMs(l.diff)}</span>
    </div>`;
  }).join('');
}

function swReset() {
  swRunning = false; swStarted = false;
  clearInterval(swInterval);
  swElapsed = 0; swLaps = []; swLastLapTime = 0;
  document.getElementById('swDisplay').innerHTML = '00:00<span class="sw-ms">.00</span>';
  document.getElementById('swStartBtn').textContent = '▶ Başlat';
  document.getElementById('swLapBtn').disabled = true;
  document.getElementById('lapsCard').style.display = 'none';
  document.getElementById('lapsList').innerHTML = '';
}

// ==================== TIMER ====================
function setTimer(h,m,s) {
  document.getElementById('timerH').value = h;
  document.getElementById('timerM').value = m;
  document.getElementById('timerS').value = s;
}

function startTimer() {
  if(timerRunning) return;
  const h = parseInt(document.getElementById('timerH').value)||0;
  const m = parseInt(document.getElementById('timerM').value)||0;
  const s = parseInt(document.getElementById('timerS').value)||0;
  timerTotal = h*3600+m*60+s;
  if(timerTotal<=0) { showSnack('⚠️ Süre giriniz'); return; }
  timerRemaining = timerTotal;
  timerRunning = true;
  timerInterval = setInterval(tickTimer, 1000);
  document.getElementById('timerStartBtn').textContent = '⏱ Çalışıyor...';
}

function tickTimer() {
  if(timerRemaining<=0) {
    clearInterval(timerInterval);
    timerRunning = false;
    document.getElementById('timerStartBtn').textContent = '▶ Başlat';
    const a = createAlarmOscillator('sine',440,'beep');
    setTimeout(()=>a.stop(), 4000);
    showSnack('✅ Zamanlayıcı bitti!');
    document.getElementById('timerCircle').style.strokeDashoffset = '0';
    return;
  }
  timerRemaining--;
  const h = Math.floor(timerRemaining/3600), m = Math.floor((timerRemaining%3600)/60), s = timerRemaining%60;
  document.getElementById('timerDisplay').textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
  const pct = timerRemaining/timerTotal;
  document.getElementById('timerCircle').style.strokeDashoffset = 678.6 * (1-pct);
}

function pauseTimer() {
  if(timerRunning) {
    timerRunning = false;
    clearInterval(timerInterval);
    document.getElementById('timerStartBtn').textContent = '▶ Devam';
  } else if(timerRemaining > 0) {
    timerRunning = true;
    timerInterval = setInterval(tickTimer,1000);
    document.getElementById('timerStartBtn').textContent = '⏱ Çalışıyor...';
  }
}

function resetTimer() {
  clearInterval(timerInterval);
  timerRunning = false; timerRemaining = 0;
  document.getElementById('timerDisplay').textContent = '00:00:00';
  document.getElementById('timerStartBtn').textContent = '▶ Başlat';
  document.getElementById('timerCircle').style.strokeDashoffset = '0';
}

// ==================== COUNTDOWN ====================
function startCountdown() {
  const d = document.getElementById('cdDate').value;
  const t = document.getElementById('cdTime').value;
  const title = document.getElementById('cdTitle').value || 'Geri Sayım';
  if(!d) { showSnack('⚠️ Tarih giriniz'); return; }
  cdTarget = new Date(`${d}T${t||'00:00'}`);
  if(cdTarget <= new Date()) { showSnack('⚠️ Geçmiş bir tarih seçildi'); return; }
  document.getElementById('cdEventTitle').textContent = title;
  document.getElementById('cdDisplay').style.display = 'block';
  if(cdInterval) clearInterval(cdInterval);
  cdInterval = setInterval(updateCountdown, 1000);
  updateCountdown();
}

function updateCountdown() {
  const diff = cdTarget - new Date();
  if(diff <= 0) {
    clearInterval(cdInterval);
    document.getElementById('cdDays').textContent = '00';
    document.getElementById('cdHours').textContent = '00';
    document.getElementById('cdMins').textContent = '00';
    document.getElementById('cdSecs').textContent = '00';
    showSnack('🎉 Geri sayım bitti!');
    return;
  }
  const d = Math.floor(diff/86400000);
  const h = Math.floor((diff%86400000)/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  document.getElementById('cdDays').textContent = pad(d);
  document.getElementById('cdHours').textContent = pad(h);
  document.getElementById('cdMins').textContent = pad(m);
  document.getElementById('cdSecs').textContent = pad(s);
}

function stopCountdown() {
  clearInterval(cdInterval);
  document.getElementById('cdDisplay').style.display = 'none';
}

// ==================== WORLD CLOCKS ====================
const worldCities = [
  {city:'İstanbul',tz:'Europe/Istanbul',flag:'🇹🇷'},
  {city:'Londra',tz:'Europe/London',flag:'🇬🇧'},
  {city:'Paris',tz:'Europe/Paris',flag:'🇫🇷'},
  {city:'Berlin',tz:'Europe/Berlin',flag:'🇩🇪'},
  {city:'Moskova',tz:'Europe/Moscow',flag:'🇷🇺'},
  {city:'Dubai',tz:'Asia/Dubai',flag:'🇦🇪'},
  {city:'Hindistan',tz:'Asia/Kolkata',flag:'🇮🇳'},
  {city:'Singapur',tz:'Asia/Singapore',flag:'🇸🇬'},
  {city:'Tokyo',tz:'Asia/Tokyo',flag:'🇯🇵'},
  {city:'Sidney',tz:'Australia/Sydney',flag:'🇦🇺'},
  {city:'New York',tz:'America/New_York',flag:'🇺🇸'},
  {city:'Chicago',tz:'America/Chicago',flag:'🇺🇸'},
  {city:'Los Angeles',tz:'America/Los_Angeles',flag:'🇺🇸'},
  {city:'São Paulo',tz:'America/Sao_Paulo',flag:'🇧🇷'},
  {city:'Kahire',tz:'Africa/Cairo',flag:'🇪🇬'},
  {city:'Pekin',tz:'Asia/Shanghai',flag:'🇨🇳'},
];

function updateWorldClocks() {
  const grid = document.getElementById('worldGrid');
  const now = new Date();
  grid.innerHTML = worldCities.map(c => {
    const timeStr = now.toLocaleTimeString('tr', {timeZone:c.tz, hour:'2-digit', minute:'2-digit', second:'2-digit'});
    const offset = getOffset(c.tz);
    return `<div class="world-card">
      <div class="world-flag">${c.flag}</div>
      <div class="world-city">${c.city}</div>
      <div class="world-time" id="wt-${c.tz.replace(/\//g,'-')}">${timeStr}</div>
      <div class="world-offset">UTC${offset}</div>
    </div>`;
  }).join('');

  setInterval(()=>{
    const now2 = new Date();
    worldCities.forEach(c => {
      const el = document.getElementById('wt-'+c.tz.replace(/\//g,'-'));
      if(el) el.textContent = now2.toLocaleTimeString('tr',{timeZone:c.tz,hour:'2-digit',minute:'2-digit',second:'2-digit'});
    });
  }, 1000);
}

function getOffset(tz) {
  const now = new Date();
  const parts = now.toLocaleString('en', {timeZone:tz,timeZoneName:'shortOffset'}).split(' ');
  const off = parts[parts.length-1];
  return off.replace('GMT','') || '+0';
}

// ==================== TIMEZONE TABLE ====================
const tzList = [
  {name:'UTC−12:00',offset:-12},{name:'UTC−11:00',offset:-11},{name:'UTC−10:00 (Hawaii)',offset:-10},
  {name:'UTC−09:00 (Alaska)',offset:-9},{name:'UTC−08:00 (Los Angeles)',offset:-8},{name:'UTC−07:00 (Denver)',offset:-7},
  {name:'UTC−06:00 (Chicago)',offset:-6},{name:'UTC−05:00 (New York)',offset:-5},{name:'UTC−04:00',offset:-4},
  {name:'UTC−03:00 (São Paulo)',offset:-3},{name:'UTC−02:00',offset:-2},{name:'UTC−01:00',offset:-1},
  {name:'UTC+00:00 (Londra)',offset:0},{name:'UTC+01:00 (Paris/Berlin)',offset:1},{name:'UTC+02:00 (Kahire)',offset:2},
  {name:'UTC+03:00 (İstanbul/Moskova)',offset:3},{name:'UTC+03:30 (Tahran)',offset:3.5},
  {name:'UTC+04:00 (Dubai)',offset:4},{name:'UTC+04:30 (Kabil)',offset:4.5},
  {name:'UTC+05:00 (Karaçi)',offset:5},{name:'UTC+05:30 (Yeni Delhi)',offset:5.5},
  {name:'UTC+06:00 (Dakar)',offset:6},{name:'UTC+07:00 (Bangkok)',offset:7},
  {name:'UTC+08:00 (Pekin/Singapur)',offset:8},{name:'UTC+09:00 (Tokyo)',offset:9},
  {name:'UTC+09:30 (Darwin)',offset:9.5},{name:'UTC+10:00 (Sidney)',offset:10},
  {name:'UTC+11:00',offset:11},{name:'UTC+12:00 (Auckland)',offset:12},
  {name:'UTC+13:00 (Samoa)',offset:13},{name:'UTC+14:00',offset:14},
];

function updateTZTable() {
  const now = new Date();
  document.getElementById('tzBody').innerHTML = tzList.map(tz => {
    const local = new Date(now.getTime() + (tz.offset * 3600 + now.getTimezoneOffset() * 60) * 1000);
    const timeStr = local.toTimeString().slice(0,8);
    return `<tr><td>${tz.name}</td><td style="color:var(--accent);font-family:'Space Mono',monospace;">UTC${tz.offset>=0?'+':''}${tz.offset}</td><td style="font-family:'Space Mono',monospace;">${timeStr}</td></tr>`;
  }).join('');
}

// ==================== WEEK ====================
function getWeekNumber(d) {
  const date = new Date(Date.UTC(d.getFullYear(),d.getMonth(),d.getDate()));
  const dayNum = date.getUTCDay()||7;
  date.setUTCDate(date.getUTCDate()+4-dayNum);
  const yearStart = new Date(Date.UTC(date.getUTCFullYear(),0,1));
  return Math.ceil((((date-yearStart)/86400000)+1)/7);
}

function updateWeek() {
  const now = new Date();
  const wn = getWeekNumber(now);
  document.getElementById('weekNum').textContent = wn;
  document.getElementById('weekInfo').innerHTML = `
    ${now.getFullYear()} yılının <strong style="color:var(--accent);">${wn}.</strong> haftası<br>
    Hafta başlangıcı: Pazartesi &nbsp;|&nbsp; ISO 8601
  `;

  // Mini calendar
  const year = now.getFullYear();
  let rows = '<table class="tz-table"><thead><tr><th>#</th><th>Pzt</th><th>Sal</th><th>Çar</th><th>Per</th><th>Cum</th><th>Cmt</th><th>Paz</th></tr></thead><tbody>';
  for(let w=1;w<=52;w++){
    rows += `<tr${w===wn?' style="background:rgba(0,212,255,0.05)"':''}>`;
    rows += `<td style="color:var(--accent);font-family:'Space Mono',monospace;">${w}</td>`;
    // Get Mon of week w
    const jan4 = new Date(year,0,4);
    const dayOfWeek = jan4.getDay()||7;
    const mon = new Date(jan4.getTime() - (dayOfWeek-1)*86400000 + (w-1)*7*86400000);
    for(let d=0;d<7;d++){
      const dd = new Date(mon.getTime()+d*86400000);
      const isToday = dd.toDateString()===now.toDateString();
      rows += `<td style="${isToday?'color:var(--accent);font-weight:700;':dd.getMonth()!==new Date(year,0,1).getMonth()&&w===1?'color:var(--text3);':''}">${dd.getDate()}</td>`;
    }
    rows += '</tr>';
  }
  rows += '</tbody></table>';
  document.getElementById('weekCalendar').innerHTML = rows;
}

// ==================== DATE CALC ====================
function calcDate() {
  const from = new Date(document.getElementById('dateFrom').value);
  const to = new Date(document.getElementById('dateTo').value);
  if(isNaN(from)||isNaN(to)) { showSnack('⚠️ Tarih giriniz'); return; }
  const diff = Math.abs(to-from);
  const days = Math.floor(diff/86400000);
  const weeks = Math.floor(days/7);
  const months = Math.abs((to.getFullYear()-from.getFullYear())*12+(to.getMonth()-from.getMonth()));
  const years = Math.abs(to.getFullYear()-from.getFullYear());
  const hours = Math.floor(diff/3600000);
  const minutes = Math.floor(diff/60000);

  document.getElementById('dateResultGrid').innerHTML = [
    {n:days,u:'Gün'},{n:weeks,u:'Hafta'},{n:months,u:'Ay'},
    {n:years,u:'Yıl'},{n:hours,u:'Saat'},{n:minutes,u:'Dakika'}
  ].map(r=>`<div class="result-item"><div class="result-num">${r.n.toLocaleString('tr')}</div><div class="result-unit">${r.u}</div></div>`).join('');
  document.getElementById('dateResult').classList.add('visible');
}

// ==================== HOURS CALC ====================
function addHoursRow() {
  const row = document.createElement('div');
  row.className = 'hours-row';
  row.innerHTML = `<input type="time" class="start-time"><input type="time" class="end-time"><button class="btn-icon" onclick="removeHoursRow(this)">✕</button>`;
  document.getElementById('hoursRows').appendChild(row);
}

function removeHoursRow(btn) {
  const rows = document.querySelectorAll('.hours-row');
  if(rows.length > 1) btn.closest('.hours-row').remove();
}

function calcHours() {
  let totalMins = 0;
  document.querySelectorAll('.hours-row').forEach(row => {
    const s = row.querySelector('.start-time').value;
    const e = row.querySelector('.end-time').value;
    if(s && e) {
      const [sh,sm] = s.split(':').map(Number);
      const [eh,em] = e.split(':').map(Number);
      let diff = (eh*60+em) - (sh*60+sm);
      if(diff < 0) diff += 1440;
      totalMins += diff;
    }
  });
  const h = Math.floor(totalMins/60), m = totalMins%60;
  document.getElementById('hoursResultText').textContent = `${pad(h)} saat ${pad(m)} dakika`;
  document.getElementById('hoursResult').classList.add('visible');
}

// ==================== AGE CALC ====================
function calcAge() {
  const birth = new Date(document.getElementById('birthDate').value);
  if(isNaN(birth)) { showSnack('⚠️ Doğum tarihi giriniz'); return; }
  const now = new Date();
  if(birth > now) { showSnack('⚠️ Geçerli bir tarih giriniz'); return; }

  let years = now.getFullYear() - birth.getFullYear();
  let months = now.getMonth() - birth.getMonth();
  let days = now.getDate() - birth.getDate();

  if(days < 0) { months--; const prev = new Date(now.getFullYear(), now.getMonth(), 0); days += prev.getDate(); }
  if(months < 0) { years--; months += 12; }

  const totalDays = Math.floor((now-birth)/86400000);
  const totalWeeks = Math.floor(totalDays/7);
  const totalHours = Math.floor((now-birth)/3600000);
  const totalMins = Math.floor((now-birth)/60000);

  // Next birthday
  const nextBirth = new Date(now.getFullYear(), birth.getMonth(), birth.getDate());
  if(nextBirth < now) nextBirth.setFullYear(now.getFullYear()+1);
  const daysLeft = Math.ceil((nextBirth-now)/86400000);

  document.getElementById('ageResultGrid').innerHTML = [
    {n:years,u:'Yıl'},{n:months,u:'Ay'},{n:days,u:'Gün'},
    {n:totalDays.toLocaleString('tr'),u:'Toplam Gün'},{n:totalWeeks.toLocaleString('tr'),u:'Toplam Hafta'},
    {n:totalHours.toLocaleString('tr'),u:'Toplam Saat'}
  ].map(r=>`<div class="result-item"><div class="result-num" style="font-size:22px;">${r.n}</div><div class="result-unit">${r.u}</div></div>`).join('');

  document.getElementById('ageExtra').innerHTML = `
    🎂 Bir sonraki doğum gününüze <strong style="color:var(--accent);">${daysLeft}</strong> gün kaldı.
    (<strong>${birth.getDate()} ${MONTHS[birth.getMonth()]}</strong>)
    <br>🗓 Toplam <strong style="color:var(--accent);">${totalMins.toLocaleString('tr')}</strong> dakika yaşadınız.
  `;

  document.getElementById('ageResult').classList.add('visible');
}

// ==================== SNACK ====================
function showSnack(msg) {
  const s = document.getElementById('snack');
  s.textContent = msg;
  s.classList.add('show');
  setTimeout(()=>s.classList.remove('show'), 3000);
}

// ==================== SET DEFAULTS ====================
(function() {
  const now = new Date();
  document.getElementById('dateFrom').value = now.toISOString().slice(0,10);
  document.getElementById('dateTo').value = now.toISOString().slice(0,10);
  document.getElementById('birthDate').value = '2000-01-01';
  document.getElementById('cdDate').value = `${now.getFullYear()+1}-01-01`;
})();

// ==================== AUTO TRANSLATE ====================
(function() {
  // Tarayıcı dilini al (örn: "en-US" → "en")
  const browserLang = (navigator.language || navigator.userLanguage || 'tr').split('-')[0].toLowerCase();
  // Türkçe ise çevirmeye gerek yok
  if (browserLang === 'tr') return;

  // Google Translate desteklediği diller
  const supported = ['en','de','fr','es','it','pt','ru','ar','zh','ja','ko','nl','pl','uk',
    'af','sq','am','hy','az','eu','be','bn','bs','bg','ca','ceb','ny','co','hr','cs','da',
    'eo','et','tl','fi','fy','gl','ka','el','gu','ht','ha','haw','iw','hi','hmn','hu','is',
    'ig','id','ga','jw','kn','kk','km','rw','ku','ky','lo','la','lv','lt','lb','mk','mg',
    'ms','ml','mt','mi','mr','mn','my','ne','no','or','ps','fa','pa','ro','sm','gd','sr',
    'st','sn','sd','si','sk','sl','so','su','sw','sv','tg','ta','tt','te','th','tr','tk',
    'ug','ur','uz','vi','cy','xh','yi','yo','zu'];

  const targetLang = supported.includes(browserLang) ? browserLang : 'en';

  // Google Translate script yükle
  window.googleTranslateElementInit = function() {
    new google.translate.TranslateElement({
      pageLanguage: 'tr',
      includedLanguages: supported.join(','),
      autoDisplay: true,
      multilanguagePage: false,
      gaTrack: false
    }, 'google_translate_element');

    // Widget yüklendikten sonra hedef dile otomatik geç
    setTimeout(function() {
      const select = document.querySelector('.goog-te-combo');
      if (select && select.value !== targetLang) {
        select.value = targetLang;
        select.dispatchEvent(new Event('change'));
      }
    }, 800);
  };

  const script = document.createElement('script');
  script.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
  script.async = true;
  document.head.appendChild(script);

  // Widget container'ı gizle (otomatik çevirince görünmesine gerek yok)
  const style = document.createElement('style');
  style.textContent = '#google_translate_element { position:fixed; bottom:70px; right:16px; z-index:9999; } .goog-te-banner-frame, .skiptranslate > iframe { display:none!important; } body { top:0!important; }';
  document.head.appendChild(style);
})();
</script>
</body>
</html>
